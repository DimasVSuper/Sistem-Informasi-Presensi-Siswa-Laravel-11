{
  "info": {
    "name": "PresensiGo API Tests",
    "description": "Postman collection untuk menguji endpoint /api/presensi pada aplikasi PresensiGo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Presensi Sukses",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"qr_code\": \"QR-API-TEST\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/presensi",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "presensi"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Success boolean true', function () {",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});",
              "pm.test('Response returns siswa data', function () {",
              "    pm.expect(jsonData.data).to.have.property('nama');",
              "    pm.expect(jsonData.data).to.have.property('nis');",
              "    pm.expect(jsonData.data).to.have.property('tanggal');",
              "    pm.expect(jsonData.data).to.have.property('waktu');",
              "    pm.expect(jsonData.data).to.have.property('status');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Invalid QR Code",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"qr_code\": \"QR-UNKNOWN\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/presensi",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "presensi"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Success boolean false', function () {",
              "    pm.expect(jsonData.success).to.eql(false);",
              "});",
              "pm.test('Message indicates invalid QR Code', function () {",
              "    pm.expect(jsonData.message).to.include('QR Code tidak valid');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Duplicate Presensi Hari Ini",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"qr_code\": \"QR-API-DUP\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/presensi",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "presensi"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 409', function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Success boolean false', function () {",
              "    pm.expect(jsonData.success).to.eql(false);",
              "});",
              "pm.test('Message indicates duplicate scan', function () {",
              "    pm.expect(jsonData.message).to.include('sudah melakukan presensi hari ini');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Missing QR Code",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{base_url}}/api/presensi",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "presensi"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 422', function () {",
              "    pm.response.to.have.status(422);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Success boolean false', function () {",
              "    pm.expect(jsonData.success).to.eql(false);",
              "});",
              "pm.test('qr_code validation error exists', function () {",
              "    pm.expect(jsonData.data).to.have.property('qr_code');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
